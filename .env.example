# Frontend: set these in Vercel, then redeploy the frontend.
REACT_APP_API_BASE_URL=https://aerogauge-api.onrender.com
REACT_APP_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Backend: set these in Render, then redeploy the backend.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
DEVICE_TOKEN=change-this-device-token
TELEMETRY_SECRET=change-this-telemetry-secret
DEFAULT_ORGANISATION=Aero-Mesh Operations
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Hardware bridge: set these on the computer physically connected to the ESP32.
FLASK_UPDATE_URL=https://aerogauge-api.onrender.com/update
SERIAL_PORT=
BAUD_RATE=115200
